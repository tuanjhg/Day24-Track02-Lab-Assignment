#!/bin/bash
set -e

echo "Running security checks..."

PYTHON=""
for candidate in ".venv/bin/python" ".venv/Scripts/python.exe" "python"; do
    if "$candidate" -c "import sys" >/dev/null 2>&1; then
        PYTHON="$candidate"
        break
    fi
done

if [ -z "$PYTHON" ]; then
    echo "Python was not found. Activate .venv or install Python before committing."
    exit 1
fi

if command -v git-secrets >/dev/null 2>&1; then
    git secrets --pre_commit_hook -- "$@"
elif git secrets --version >/dev/null 2>&1; then
    git secrets --pre_commit_hook -- "$@"
else
    echo "git-secrets is not installed; running local credential-pattern fallback."
    "$PYTHON" scripts/security_scan.py .
fi

echo "Running Bandit SAST..."
"$PYTHON" -m bandit -r src/ -ll -q

echo "Checking dependencies for CVEs..."
"$PYTHON" -m pip_audit --desc on

echo "All security checks passed."
